// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Asset {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  equipment Equipment[]
}

model Equipment {
  id      Int    @id @default(autoincrement())
  name    String @unique @db.VarChar(255)
  assetId Int

  asset Asset  @relation(fields: [assetId], references: [id])
  part  Part[]
}

model Part {
  id          Int    @id @default(autoincrement())
  name        String @db.VarChar(255)
  equipmentId Int

  equipment Equipment       @relation(fields: [equipmentId], references: [id])
  partLoss  PartParameter[]
}

model ParameterType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  partParameter PartParameter[]
}

model PartParameter {
  id              Int    @id @default(autoincrement())
  name            String @db.VarChar(255)
  partId          Int
  parameterTypeId Int

  part          Part          @relation(fields: [partId], references: [id])
  parameterType ParameterType @relation(fields: [parameterTypeId], references: [id])
  PHDTag        PHDTag[]
}

model Unit {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  PHDTag PHDTag[]
}

model PHDTag {
  id              Int    @id @default(autoincrement())
  tagname         String @unique @db.VarChar(300)
  partParameterId Int
  unitId          Int

  partParameter PartParameter @relation(fields: [partParameterId], references: [id])
  unit          Unit          @relation(fields: [unitId], references: [id])
  record        Record[]
}

model Record {
  id        Int      @id @default(autoincrement())
  value     Decimal
  PHDTagId  Int
  timestamp DateTime

  PHDTag PHDTag @relation(fields: [PHDTagId], references: [id])
}
