// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Area {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  asset Asset[]
}

model Asset {
  id     Int    @id @default(autoincrement())
  name   String @unique @db.VarChar(255)
  areaId Int

  area      Area        @relation(fields: [areaId], references: [id])
  equipment Equipment[]
}

model Equipment {
  id      Int    @id @default(autoincrement())
  name    String @db.VarChar(255)
  assetId Int

  asset     Asset       @relation(fields: [assetId], references: [id])
  attribute Attribute[]
}

model AttributeType {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  attribute Attribute[]
}

model Attribute {
  id              Int    @id @default(autoincrement())
  name            String @db.VarChar(255)
  equipmentId     Int
  attributeTypeId Int

  equipment     Equipment     @relation(fields: [equipmentId], references: [id])
  attributeType AttributeType @relation(fields: [attributeTypeId], references: [id])
  assignment    Assignment[]
}

model Unit {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(255)

  PHDTag PHDTag[]
}

model PHDTag {
  id      Int    @id @default(autoincrement())
  tagname String @unique @db.VarChar(300)
  unitId  Int

  unit       Unit         @relation(fields: [unitId], references: [id])
  record     Record[]
  assignment Assignment[]
}

model Assignment {
  attributeTypeId Int
  PHDTagId        Int

  attribute Attribute @relation(fields: [attributeTypeId], references: [id])
  PHDTag    PHDTag    @relation(fields: [PHDTagId], references: [id])

  @@id([attributeTypeId, PHDTagId])
}

model Record {
  id        Int      @id @default(autoincrement())
  value     Decimal
  PHDTagId  Int
  timestamp DateTime

  PHDTag PHDTag @relation(fields: [PHDTagId], references: [id])
}
